<%- | String $bind,
      Integer $difficulty,
      String $metrics_bind,
      Variant[Integer, Boolean] $serve_robots,
      String $target,
      String $cookie_domain,
      String $policy_fname | -%>
BIND=<%= $bind %>
DIFFICULTY=<%= $difficulty %>
METRICS_BIND=<%= $metrics_bind %>
SERVE_ROBOTS_TXT=<%= $serve_robots ? { true => 1, false => 0, default => $serve_robots } %>
TARGET=<%= $target %>
COOKIE_DOMAIN=<%= $cookie_domain %>
POLICY_FNAME=<%= $policy_fname %>
